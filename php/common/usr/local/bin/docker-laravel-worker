#!/usr/bin/env sh
set -eu

APP_BASE_DIR="${APP_BASE_DIR:-/app}"
SUPERCRONIC="${SUPERCRONIC:-/usr/local/bin/supercronic}"

usage() {
  echo "Usage: docker-laravel-worker queue|horizon|scheduler|combined [--queue=default]" >&2
  exit 64
}

require_supercronic() {
  if [ ! -x "$SUPERCRONIC" ]; then
    echo "supercronic not found or not executable at: $SUPERCRONIC" >&2
    exit 70
  fi
}

write_crontab() {
  crontab="/tmp/crontab"
  echo "* * * * * cd $APP_BASE_DIR && php artisan schedule:run" > "$crontab"
  echo "$crontab"
}

mode="${1:-}"
[ -n "$mode" ] || usage
shift || true

queue="${WORKER_QUEUE:-default}"

while [ "$#" -gt 0 ]; do
  case "$1" in
    --queue=*) queue="${1#--queue=}" ;;
    --queue) shift; [ "$#" -gt 0 ] || usage; queue="$1" ;;
    *) usage ;;
  esac
  shift || true
done

case "$mode" in
  queue)
    exec php artisan queue:work --queue="$queue"
    ;;

  horizon)
    exec php artisan horizon
    ;;

  scheduler)
    require_supercronic
    crontab="$(write_crontab)"
    exec "$SUPERCRONIC" -quiet -passthrough-logs "$crontab"
    ;;

  combined)
    require_supercronic
    crontab="$(write_crontab)"

    "$SUPERCRONIC" -quiet -passthrough-logs "$crontab" &
    scheduler_pid="$!"

    php artisan queue:work --queue="$queue" &
    queue_pid="$!"

    terminate() {
      kill -TERM "$scheduler_pid" "$queue_pid" 2>/dev/null || true
      wait "$scheduler_pid" 2>/dev/null || true
      wait "$queue_pid" 2>/dev/null || true
    }

    trap 'terminate; exit 143' TERM INT

    while :; do
      if ! kill -0 "$scheduler_pid" 2>/dev/null; then
        wait "$scheduler_pid" || status="$?"
        terminate
        exit "${status:-1}"
      fi

      if ! kill -0 "$queue_pid" 2>/dev/null; then
        wait "$queue_pid" || status="$?"
        terminate
        exit "${status:-1}"
      fi

      sleep 1
    done
    ;;

  *)
    usage
    ;;
esac
