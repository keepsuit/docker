#!/usr/bin/env sh

# auto | true | false
SCHEDULE_WHISPER="${SCHEDULE_WHISPER:-auto}"

schedule_run_supports_whisper() {
	help_output="$(php artisan schedule:run --help 2>/dev/null || true)"

	case "$help_output" in
	*"--whisper"*) return 0 ;;
	*) return 1 ;;
	esac
}

schedule_run_command() {
	case "$SCHEDULE_WHISPER" in
	true)
		if ! schedule_run_supports_whisper; then
			echo "php artisan schedule:run does not support --whisper; Laravel >= 12.20 is required" >&2
			exit 70
		fi

		echo "php artisan schedule:run --no-interaction --whisper"
		;;

	false)
		echo "php artisan schedule:run --no-interaction"
		;;

	auto)
		if schedule_run_supports_whisper; then
			echo "php artisan schedule:run --no-interaction --whisper"
		else
			echo "php artisan schedule:run --no-interaction"
		fi
		;;

	*)
		echo "invalid SCHEDULE_WHISPER value: $SCHEDULE_WHISPER; expected auto, true, or false" >&2
		exit 64
		;;
	esac
}
